{
  "manifest_version": 3,
  "name": "Tiny Stopwatch",
  "version": "1.1.1",
  "description": "クリックで開始・停止。右クリックでリセットと配色切替。ホバーには計測中は時・分・秒、停止後は0.1秒まで表示します。",
  "minimum_chrome_version": "110",
  "permissions": [
    "alarms",
    "contextMenus",
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "00:00:00.0 — Tiny Stopwatch — stopped; click to start",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
