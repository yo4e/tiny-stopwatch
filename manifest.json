{
  "manifest_version": 3,
  "name": "Tiny Stopwatch",
  "version": "1.0.0",
  "description": "A tiny stopwatch that lives in your Chrome toolbar.",
  "minimum_chrome_version": "110",
  "permissions": [
    "alarms",
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tiny Stopwatch — 00:00"
  }
}
